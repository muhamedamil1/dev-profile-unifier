# ------------------------------------------------------------
# Supabase
# ------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ------------------------------------------------------------
# External APIs
# ------------------------------------------------------------
GITHUB_TOKEN=your-github-token
STACKEXCHANGE_KEY=your-stackexchange-key
# ------------------------------------------------------------
# App settings
# ------------------------------------------------------------
APP_NAME=Dev Profile Unifier
APP_VERSION=1.0.0
APP_ENV=development
LOG_LEVEL=info

REQUEST_TIMEOUT_SECONDS=20
MAX_CANDIDATES_PER_PLATFORM=3
ENABLE_LLM_AMBIGUOUS_REVIEW=false

AUTO_MATCH_THRESHOLD=0.85
NEEDS_REVIEW_THRESHOLD=0.60
EVIDENCE_CONFIDENCE_CAP=0.97


# Gemini / LLM infrastructure
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_TIMEOUT_SECONDS=30
GEMINI_MAX_RETRIES=2
GEMINI_RETRY_BASE_DELAY_SECONDS=1.0
GEMINI_RETRY_MAX_DELAY_SECONDS=8.0
GEMINI_RETRY_JITTER_RATIO=0.2
GEMINI_RATE_LIMIT_ENABLED=true
GEMINI_REQUESTS_PER_MINUTE=5
GEMINI_TOKENS_PER_MINUTE=30000
GEMINI_REQUESTS_PER_DAY=500
GEMINI_MIN_REQUEST_INTERVAL_SECONDS=12.0
GEMINI_RATE_LIMIT_MAX_WAIT_SECONDS=60.0
GEMINI_DAY_RESET_TIMEZONE=America/Los_Angeles

# Comma-separated origins.
# Example:
# BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
BACKEND_CORS_ORIGINS=